programa {
    funcao inicio() {

        inteiro numero
        inteiro soma = 0

        escreva("Digite um numero (0 para parar): ")
        leia(numero)

        enquanto (numero != 0) {

            soma = soma + numero

            escreva("Digite outro numero (0 para parar): ")
            leia(numero)
        }

        escreva("\nSoma total: ", soma)
    }
}
