programa {
	funcao inicio() {
		inteiro numero, maior, i = 2

		escreva("Digite o 1º número: ")
		leia(maior)

		enquanto (i <= 5) {
			escreva("Digite o ", i, "º número: ")
			leia(numero)

			se (numero > maior) {
				maior = numero
			}
			i = i + 1
		}

		escreva("O maior valor digitado foi: ", maior)
	}
}
